---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroPlaceholder from "../components/HeroPlaceholder.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About"
			description={`About ${SITE_TITLE} — a notebook kept in public.`}
		/>
	</head>
	<body>
		<div class="flex flex-col min-h-screen">
			<Header />
			<div class="flex-1 w-full animate-fade-in">
				<main class="max-w-shell mx-auto pt-[72px] pb-24 px-gutter w-full">
					<section class="max-w-reading mb-16">
						<p
							class="font-mono text-[11px] tracking-[0.18em] uppercase text-muted mb-[18px] inline-block"
						>
							About
						</p>
						<h1
							class="font-display font-light italic text-[clamp(28px,3.4vw,40px)] leading-[1.2] tracking-[-0.015em] text-ink m-0 text-pretty"
						>
							I write about the practice of making things, the slow work of a life,
							and the small disciplines that hold both together.
						</h1>
					</section>

					<div
						class="grid grid-cols-[280px_1fr] gap-16 max-w-[980px] max-[800px]:grid-cols-1 max-[800px]:gap-8"
					>
						<div class="max-[800px]:max-w-[280px]">
							<HeroPlaceholder label="portrait" aspect="3 / 4" />
						</div>
						<div class="font-body text-[18px] leading-[1.7] text-ink-2">
							<p class="mb-5 text-pretty">
								I'm Kyan. I've spent the last fifteen years building software at the
								seam between design and engineering — most recently leading product
								at a small studio you probably haven't heard of, and that's the way
								we like it.
							</p>
							<p class="mb-5 text-pretty">
								This site is a notebook, kept in public, mostly for myself. I write
								here when I have something I want to remember — a turn of phrase, a
								small idea, a thing I learned from a piece of work that did not go
								the way I hoped.
							</p>
							<p class="mb-5 text-pretty">
								I try to publish every few weeks. Sometimes I miss. The essays here
								are short, and I would rather they were good than frequent.
							</p>

							<h2
								class="font-display font-medium text-[22px] tracking-[-0.01em] text-ink mt-12 mb-4"
							>
								Elsewhere
							</h2>
							<ul class="list-none m-0 mb-4 p-0">
								<li
									class="grid grid-cols-[90px_1fr] gap-4 py-2.5 border-t border-rule text-[16px] last:border-b"
								>
									<span
										class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted pt-1"
										>Email</span
									>
									<a
										href="mailto:kyan@kyanravanagh.com"
										class="text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent"
										>kyan@kyanravanagh.com</a
									>
								</li>
								<li
									class="grid grid-cols-[90px_1fr] gap-4 py-2.5 border-t border-rule text-[16px] last:border-b"
								>
									<span
										class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted pt-1"
										>Twitter</span
									>
									<a
										href="#"
										class="text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent"
										>@kyanravanagh</a
									>
								</li>
								<li
									class="grid grid-cols-[90px_1fr] gap-4 py-2.5 border-t border-rule text-[16px] last:border-b"
								>
									<span
										class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted pt-1"
										>GitHub</span
									>
									<a
										href="#"
										class="text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent"
										>github.com/kyanravanagh</a
									>
								</li>
								<li
									class="grid grid-cols-[90px_1fr] gap-4 py-2.5 border-t border-rule text-[16px] last:border-b"
								>
									<span
										class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted pt-1"
										>Reading</span
									>
									<a
										href="#"
										class="text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent"
										>What I'm reading now</a
									>
								</li>
							</ul>

							<h2
								class="font-display font-medium text-[22px] tracking-[-0.01em] text-ink mt-12 mb-4"
							>
								Colophon
							</h2>
							<p class="mb-5 text-pretty">
								Set in Newsreader for display and Source Serif 4 for body, with
								JetBrains Mono for small notations. Built with Astro, hosted on
								Cloudflare. No analytics, no tracking, no cookie banner. Hand-built
								and quietly maintained.
							</p>

							<p class="mt-10">
								<a
									href="/"
									class="font-mono text-[12px] tracking-[0.12em] uppercase text-accent border-b border-accent pb-1"
								>
									← Back to writing
								</a>
							</p>
						</div>
					</div>
				</main>
			</div>
			<Footer />
		</div>
	</body>
</html>
