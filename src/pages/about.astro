---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroPlaceholder from "../components/HeroPlaceholder.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About"
			description={`About ${SITE_TITLE} — a notebook kept in public.`}
		/>
	</head>
	<body>
		<div class="flex flex-col min-h-screen">
			<Header />
			<div class="flex-1 w-full animate-fade-in motion-reduce:animate-none">
				<main id="main-content" class="max-w-shell mx-auto pt-[72px] pb-24 px-gutter w-full">
					<section class="max-w-reading mb-16">
						<p
							class="font-mono text-[11px] tracking-[0.18em] uppercase text-muted mb-[18px] inline-block"
						>
							About
						</p>
						<h1
							class="font-display font-light italic text-[clamp(28px,3.4vw,40px)] leading-[1.2] tracking-[-0.015em] text-ink m-0 text-pretty"
						>
							I write about whatever takes my fancy. I hope you find my musings — more accurately, ramblings — somewhat interesting.
						</h1>
					</section>

					<div
						class="grid grid-cols-[280px_1fr] gap-16 max-w-[980px] max-[800px]:grid-cols-1 max-[800px]:gap-8"
					>
						<div class="max-[800px]:max-w-[280px]">
							<HeroPlaceholder label="portrait" aspect="3 / 4" />
						</div>
						<div class="font-body text-[18px] leading-[1.7] text-ink-2">
							<p class="mb-5 text-pretty">
								I'm Ryan and I still need to write this summary
							</p>

							<h2
								class="font-display font-medium text-[22px] tracking-[-0.01em] text-ink mt-12 mb-4"
							>
								Elsewhere
							</h2>
							<ul class="list-none m-0 mb-4 p-0">
								<li
									class="grid grid-cols-[90px_1fr] gap-4 py-2.5 border-t border-rule text-[16px] last:border-b"
								>
									<span
										class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted pt-1"
										>GitHub</span
									>
									<a
										href="https://github.com/ryankav"
										class="text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-deep"
										>ryankav</a
									>
								</li>
								<li
									class="grid grid-cols-[90px_1fr] gap-4 py-2.5 border-t border-rule text-[16px] last:border-b"
								>
									<span
										class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted pt-1"
										>Reading</span
									>
									<a
										href="https://en.wikipedia.org/wiki/The_Story_of_a_New_Name"
										class="text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-deep"
										>The Story of a New Name</a
									>
								</li>
							</ul>

							<p class="mt-10">
								<a
									href="/"
									class="font-mono text-[12px] tracking-[0.12em] uppercase text-accent border-b border-accent pb-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-deep"
								>
									← Back to writing
								</a>
							</p>
						</div>
					</div>
				</main>
			</div>
			<Footer />
		</div>
	</body>
</html>
