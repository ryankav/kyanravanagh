---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import HeroPlaceholder from "../components/HeroPlaceholder.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="flex flex-col min-h-screen">
			<Header />
			<div class="flex-1 w-full animate-fade-in">
				<main class="max-w-shell mx-auto pt-[72px] pb-24 px-gutter w-full">
					{
						featured && (
							<a href={`/blog/${featured.id}/`} class="block max-w-reading mb-20 group">
								<div class="flex items-center gap-2.5 font-mono text-[11px] tracking-[0.12em] uppercase text-muted mb-4">
									<span class="text-accent font-medium">{featured.data.tag}</span>
									<span class="text-muted-2" aria-hidden="true">·</span>
									<span>
										<FormattedDate date={featured.data.pubDate} />
									</span>
									{featured.data.readingTime && (
										<>
											<span class="text-muted-2" aria-hidden="true">·</span>
											<span>{featured.data.readingTime} min read</span>
										</>
									)}
								</div>
								<h2 class="font-display font-normal text-[clamp(34px,5vw,56px)] leading-[1.08] tracking-[-0.022em] mb-[18px] text-ink text-balance transition-colors group-hover:text-accent-deep">
									{featured.data.title}
								</h2>
								<p class="font-display italic font-light text-[clamp(18px,1.6vw,22px)] leading-[1.5] text-ink-2 mb-8 max-w-[620px] text-pretty">
									{featured.data.description}
								</p>
								<div class="mb-6">
									<HeroPlaceholder
										label="featured essay artwork"
										aspect="16 / 9"
										src={featured.data.heroImage}
										alt={featured.data.title}
									/>
								</div>
								<span class="inline-flex items-center gap-2.5 font-mono text-[12px] tracking-[0.12em] uppercase text-accent border-b border-accent pb-1 transition-[gap] group-hover:gap-3.5">
									Read the essay <span aria-hidden="true">→</span>
								</span>
							</a>
						)
					}

          {
            rest.length > 0 && (
					    <hr class="h-px bg-rule max-w-reading mb-14 border-none" aria-hidden="true" />

					    <section class="max-w-reading">
					    	<header class="flex items-baseline justify-between mb-8 gap-6">
					    		<h3 class="font-display font-normal text-[22px] tracking-[-0.01em] m-0 text-ink">
					    			Recent writing
					    		</h3>
					    		<a
					    			href="/blog/"
					    			class="font-mono text-[11px] tracking-[0.14em] uppercase text-muted transition-colors hover:text-accent"
					    		>
					    			See all {posts.length} essays →
					    		</a>
					    	</header>
					    	<ol class="list-none m-0 p-0 flex flex-col">
					    		{
					    			rest.map((p) => (
					    				<li class="border-t border-rule last:border-b">
					    					<a
					    						href={`/blog/${p.id}/`}
					    						class="grid grid-cols-[110px_1fr] gap-8 py-7 items-baseline transition-colors hover:bg-bg-soft/60 group max-[600px]:grid-cols-1 max-[600px]:gap-2"
					    					>
					    						<div class="font-mono text-[11px] tracking-[0.14em] uppercase text-muted pt-1.5">
					    							<FormattedDate date={p.data.pubDate} format="short" />
					    						</div>
					    						<div>
					    							<h4 class="font-display font-normal text-[clamp(22px,2vw,26px)] leading-[1.2] tracking-[-0.012em] mb-2 text-ink transition-colors group-hover:text-accent-deep text-balance">
					    								{p.data.title}
					    							</h4>
					    							<p class="font-body text-[16px] leading-[1.55] text-muted mb-3 text-pretty">
					    								{p.data.description}
					    							</p>
					    							<div class="flex items-center gap-2.5 font-mono text-[10px] tracking-[0.12em] uppercase text-muted">
					    								<span class="text-accent font-medium">{p.data.tag}</span>
					    								{p.data.readingTime && (
					    									<>
					    										<span class="text-muted-2" aria-hidden="true">·</span>
					    										<span>{p.data.readingTime} min</span>
					    									</>
					    								)}
					    							</div>
					    						</div>
					    					</a>
					    				</li>
					    			))
					    		}
					    	</ol>
					    </section>
            )
          }
				</main>
			</div>
			<Footer />
		</div>
	</body>
</html>
