---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const byYear = new Map<number, typeof posts>();
for (const p of posts) {
	const y = p.data.pubDate.getFullYear();
	if (!byYear.has(y)) byYear.set(y, []);
	byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const tags = Array.from(new Set(posts.map((p) => p.data.tag)));

const earliest = posts.length
	? posts[posts.length - 1].data.pubDate.getFullYear()
	: new Date().getFullYear();
const latest = posts.length
	? posts[0].data.pubDate.getFullYear()
	: new Date().getFullYear();
const range = earliest === latest ? `${latest}` : `${earliest} and ${latest}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Archive"
			description={`Every essay published on ${SITE_TITLE}, grouped by year.`}
		/>
	</head>
	<body>
		<div class="flex flex-col min-h-screen">
			<Header />
			<div class="flex-1 w-full animate-fade-in">
				<main class="max-w-shell mx-auto pt-[72px] pb-24 px-gutter w-full">
					<section class="max-w-reading mb-12">
						<p
							class="font-mono text-[11px] tracking-[0.18em] uppercase text-muted mb-[18px] inline-block"
						>
							Archive
						</p>
						<h1
							class="font-display font-light italic text-[clamp(26px,3vw,36px)] leading-[1.2] tracking-[-0.015em] text-ink mb-7 text-pretty"
						>
							{posts.length} essays, written between {range}.
						</h1>
						<div class="flex flex-wrap gap-1.5" data-archive-tags>
							<button
								class="tag-pill is-active font-mono text-[11px] tracking-[0.12em] uppercase border px-3 py-1.5 cursor-pointer transition-all"
								data-tag="All"
							>
								All
							</button>
							{
								tags.map((t) => (
									<button
										class="tag-pill font-mono text-[11px] tracking-[0.12em] uppercase border px-3 py-1.5 cursor-pointer transition-all"
										data-tag={t}
									>
										{t}
									</button>
								))
							}
						</div>
					</section>

					<section class="max-w-reading" data-archive-list>
						{
							years.map((y) => (
								<div
									class="archive-year grid grid-cols-[90px_1fr] gap-8 py-9 border-t border-rule last:border-b max-[600px]:grid-cols-1 max-[600px]:gap-3"
									data-year={y}
								>
									<div class="font-mono text-[13px] tracking-[0.12em] text-muted mt-1.5 sticky top-[90px] self-start max-[600px]:static">
										{y}
									</div>
									<ol class="list-none m-0 p-0">
										{byYear.get(y)!.map((p) => (
											<li class="archive-item" data-tag={p.data.tag}>
												<a
													href={`/blog/${p.id}/`}
													class="grid grid-cols-[80px_1fr_100px] gap-5 py-3.5 items-baseline border-b border-dashed border-rule transition-[padding] hover:pl-2 group max-[600px]:grid-cols-[70px_1fr]"
												>
													<span class="font-mono text-[11px] tracking-[0.12em] uppercase text-muted">
														{p.data.pubDate.toLocaleDateString("en-US", {
															month: "short",
															day: "2-digit",
														})}
													</span>
													<span class="font-display font-normal text-[19px] leading-[1.3] tracking-[-0.01em] text-ink transition-colors group-hover:text-accent-deep text-balance">
														{p.data.title}
													</span>
													<span class="font-mono text-[10px] tracking-[0.14em] uppercase text-accent text-right max-[600px]:hidden">
														{p.data.tag}
													</span>
												</a>
											</li>
										))}
									</ol>
								</div>
							))
						}
					</section>
				</main>
			</div>
			<Footer />
		</div>

		<style>
			.tag-pill {
				color: var(--color-muted);
				background: transparent;
				border-color: var(--color-rule);
			}
			.tag-pill:hover {
				color: var(--color-ink);
				border-color: var(--color-rule-2);
			}
			.tag-pill.is-active {
				color: var(--color-bg);
				background: var(--color-ink);
				border-color: var(--color-ink);
			}
			.archive-item.is-hidden {
				display: none;
			}
			.archive-year.is-empty {
				display: none;
			}
		</style>

		<script>
			const tagBar = document.querySelector<HTMLDivElement>("[data-archive-tags]");
			const list = document.querySelector<HTMLDivElement>("[data-archive-list]");
			if (tagBar && list) {
				tagBar.addEventListener("click", (event) => {
					const target = event.target as HTMLElement;
					const btn = target.closest<HTMLButtonElement>("button.tag-pill");
					if (!btn) return;
					const active = btn.dataset.tag ?? "All";
					tagBar.querySelectorAll(".tag-pill").forEach((el) => {
						el.classList.toggle("is-active", el === btn);
					});
					list.querySelectorAll<HTMLLIElement>(".archive-item").forEach((item) => {
						const show = active === "All" || item.dataset.tag === active;
						item.classList.toggle("is-hidden", !show);
					});
					list.querySelectorAll<HTMLDivElement>(".archive-year").forEach((year) => {
						const visible = year.querySelectorAll(".archive-item:not(.is-hidden)").length;
						year.classList.toggle("is-empty", visible === 0);
					});
				});
			}
		</script>
	</body>
</html>
