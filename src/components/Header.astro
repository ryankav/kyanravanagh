---
import { SITE_TITLE } from "../consts";

const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname === "";
const isArchive = pathname.startsWith("/blog");
const isAbout = pathname.startsWith("/about");

const nav = [
	{ href: "/", label: "Writing", active: isHome },
	{ href: "/blog/", label: "Archive", active: isArchive },
	{ href: "/about/", label: "About", active: isAbout },
];
---

<header
	class="sticky top-0 z-50 bg-bg/90 backdrop-blur-md backdrop-saturate-150 border-b border-rule"
>
	<div
		class="max-w-shell mx-auto py-[18px] px-gutter flex items-baseline justify-between gap-8"
	>
		<a class="flex items-baseline gap-3" href="/">
			<span class="font-display font-medium text-[22px] tracking-[-0.01em] text-ink">
				{SITE_TITLE}
			</span>
		</a>
		<nav class="flex items-center gap-7">
			{
				nav.map((item) => (
					<a
						href={item.href}
						class:list={[
							"font-mono text-[12px] tracking-[0.12em] uppercase text-muted py-1 transition-colors hover:text-ink",
							item.active && "nav-link-active",
						]}
					>
						{item.label}
					</a>
				))
			}
			<a
				href="/rss.xml"
				class="inline-flex items-center font-mono text-[12px] uppercase text-muted py-1 transition-colors hover:text-ink"
				title="RSS feed"
				aria-label="RSS feed"
			>
				<svg
					width="13"
					height="13"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
					class="block"
				>
					<path d="M4 11a9 9 0 0 1 9 9"></path>
					<path d="M4 4a16 16 0 0 1 16 16"></path>
					<circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none"></circle>
				</svg>
			</a>
		</nav>
	</div>
</header>
