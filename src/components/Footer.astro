---
import { SITE_TITLE } from "../consts";
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-rule bg-bg-soft">
	<div
		class="max-w-shell mx-auto py-14 px-gutter grid grid-cols-[1fr_1.4fr_1.4fr] gap-12 max-[800px]:grid-cols-1 max-[800px]:gap-8"
	>
		<div>
			<div class="font-mono text-[11px] tracking-[0.18em] uppercase text-muted mb-4 inline-block">
				Elsewhere
			</div>
			<ul class="list-none m-0 p-0">
				<li class="mb-1.5">
					<a
						href="#"
						class="font-body text-[16px] text-ink border-b border-rule-2 transition-colors hover:text-accent hover:border-accent"
					>
						GitHub
					</a>
				</li>
			</ul>
		</div>

	</div>
</footer>
